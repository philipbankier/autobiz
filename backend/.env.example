# =============================================================================
# AutoBiz Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -- Database ------------------------------------------------------------------
# PostgreSQL connection (async driver)
DATABASE_URL=postgresql+asyncpg://autobiz:autobiz@localhost:5432/autobiz

# -- Redis ---------------------------------------------------------------------
# Used by Celery task queue and event bus
REDIS_URL=redis://localhost:6379/0

# -- Authentication ------------------------------------------------------------
# Secret key for signing JWT tokens (generate a random string)
JWT_SECRET=change-me-to-a-random-secret-key
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# -- OpenClaw Gateway ----------------------------------------------------------
# Connection to the OpenClaw multi-agent gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# -- Anthropic (fallback) -----------------------------------------------------
# Used if OpenClaw gateway is not configured
ANTHROPIC_API_KEY=

# -- Stripe (payments) --------------------------------------------------------
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -- GitHub --------------------------------------------------------------------
# Personal access token for repo creation (needs 'repo' scope)
GITHUB_PAT=

# -- Vercel --------------------------------------------------------------------
# API token for site deployment
VERCEL_TOKEN=

# -- Late (social media) ------------------------------------------------------
# API key for Twitter/LinkedIn posting via Late API
LATE_API_KEY=

# -- Resend (email) ------------------------------------------------------------
# API key for transactional email dispatch
RESEND_API_KEY=
